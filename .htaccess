# ===== הפרלמנט - hardened config =====

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS (no insecure http access)
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # Block direct access to /data/
    RewriteRule ^data/ - [F,L]

    # /demo -> האפליקציה המלאה (חוויה אינטראקטיבית במסך מלא)
    RewriteRule ^demo/?$ app.php [L,QSA]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(self), camera=(), microphone=()"
    # HSTS - force https for a year
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    # CSP - מקורות מותרים בלבד. פונטים מגוגל, הכל היתר עצמי. בלי סקריפטים זרים.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self'; worker-src 'self' blob:; child-src 'self' blob:; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
    Header always set Cross-Origin-Opener-Policy "same-origin"
</IfModule>

# Block direct access to backend includes & data files
<FilesMatch "(config\.php|auth\.php|icons\.php|init_db\.php|\.sqlite|\.sqlite-wal|\.sqlite-shm|\.log|\.htaccess|\.md)$">
    Require all denied
</FilesMatch>

# Hide directory listings
Options -Indexes

# Disable PHP error display (no path/info leakage)
<IfModule mod_php8.c>
    php_flag display_errors Off
    php_value upload_max_filesize 50M
    php_value post_max_size 55M
    php_value memory_limit 128M
    php_value max_execution_time 120
</IfModule>
<IfModule mod_php.c>
    php_flag display_errors Off
    php_value upload_max_filesize 50M
    php_value post_max_size 55M
    php_value memory_limit 128M
    php_value max_execution_time 120
</IfModule>
